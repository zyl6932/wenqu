# 知识库 RAG 系统 — 环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# LLM 配置
# provider: deepseek (需要 Key) | ollama (本地，无需 Key)
LLM_PROVIDER=deepseek
# DeepSeek 申请地址: https://platform.deepseek.com/api_keys
DEEPSEEK_KEY=sk-your-key-here
DEEPSEEK_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 如果 LLM_PROVIDER=ollama，将使用本地 Ollama 聊天模型
# DEEPSEEK_MODEL 此时应设为 Ollama 聊天模型名，如 qwen2.5, llama3 等

# Embedding 配置
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=bge-m3

# 视觉模型（PDF 图片提取用）
VISION_MODEL=minicpm-v:8b

# 服务器配置
HOST=0.0.0.0
PORT=8080

# 检索配置
CHUNK_MAX_TOKENS=400
TOP_K=10
ENABLE_QUERY_REWRITE=1   # 1=开启查询改写 0=关闭（省一次 LLM 调用）
